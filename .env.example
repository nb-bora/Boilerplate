# App
APP_ENV=dev
APP_NAME=fastapi-boilerplate
APP_LOG_LEVEL=info

# Security
# IMPORTANT: obligatoire en prod (>= 32 chars aléatoires)
APP_SECRET_KEY=change-me-in-prod-please-use-a-real-secret
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/boilerplate

# Redis (optionnel)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
