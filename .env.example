# App
APP_ENV=dev
APP_NAME=fastapi-boilerplate
APP_LOG_LEVEL=info

# Security
# IMPORTANT: obligatoire en prod (>= 32 chars aléatoires)
APP_SECRET_KEY=change-me-in-prod-please-use-a-real-secret
CORS_ORIGINS=http://localhost:3000
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/boilerplate

# Redis (optionnel)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_RETRY_ATTEMPTS=3
REDIS_RETRY_BACKOFF_MS=100

# Rate limiting
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_REGISTER_PER_HOUR=10

# Idempotency
IDEMPOTENCY_TTL_SECONDS=900

# Feature flags
SOFT_DELETE_ENABLED=false
MYPY_STRICT=false
